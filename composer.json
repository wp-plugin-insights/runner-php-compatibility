{
  "name": "wp-plugin-insights/runner-php-compatibility",
  "description": "RabbitMQ runner that detects effective PHP compatibility for WordPress plugins",
  "type": "project",
  "require": {
    "php": "^8.2",
    "php-amqplib/php-amqplib": "^3.7",
    "vlucas/phpdotenv": "^5.6",
    "squizlabs/php_codesniffer": "^3.10",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "WpPluginInsights\\RunnerPhpCompatibility\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpPluginInsights\\RunnerPhpCompatibility\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/runner",
    "bin/process-message"
  ],
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
